#!/usr/bin/env bash
# my-commands — Dispatcher for web search, page extraction, and multi-agent orchestration
# Usage: my-commands <command> [args...]
#
# Commands:
#   web-search  "query" [-n NUM] [-c CATEGORY] [-j]
#       Query SearXNG and return results.
#       -n NUM   : number of results (default 10)
#       -c CAT   : category (general, images, news, videos, IT, science, files, music)
#       -j       : raw JSON output
#
#   fetch-page  "url"
#       Download a URL and extract readable text.
#
#   agent       <subcommand> [args...]
#       Multi-agent orchestration (spawn/manage pi sub-agents).
#       Subcommands: spawn, message, messages, status, kill, stop.
#
#   help        Show this message.

set -euo pipefail

SEARXNG_URL="${SEARXNG_URL:-http://localhost:8888}"
USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36"

# ── web-search ─────────────────────────────────────────────────────
do_web_search() {
    local num_results=10 category="general" raw_json=false query=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) num_results="$2"; shift 2 ;;
            -c) category="$2"; shift 2 ;;
            -j) raw_json=true; shift ;;
            -*) echo "web-search: unknown option $1" >&2; exit 1 ;;
            *) query="$query${query:+ }$1"; shift ;;
        esac
    done

    [[ -z "$query" ]] && { echo "web-search: no query" >&2; exit 1; }

    local response
    response=$(curl -sG \
        --data-urlencode "q=$query" \
        --data-urlencode "categories=$category" \
        --data "format=json" \
        --max-time 15 \
        "$SEARXNG_URL/search" 2>/dev/null) || {
        echo "web-search: failed to reach SearXNG at $SEARXNG_URL" >&2
        exit 1
    }

    if [[ "$raw_json" == true ]]; then
        echo "$response" | jq -c ".results[:$num_results]"
        return 0
    fi

    local total
    total=$(echo "$response" | jq '.results | length')

    echo "=== Search: \"$query\" ($total results found, showing $num_results) ==="
    echo ""

    echo "$response" | jq -r "
        .results[:$num_results] | to_entries[] |
        \"## \(.key + 1). \(.value.title)
URL: \(.value.url)
Source: \(.value.engine // \"unknown\")
\(.value.content // \"No snippet available.\")
\"
    "
}

# ── fetch-page ─────────────────────────────────────────────────────
do_fetch_page() {
    local url=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) echo "fetch-page: unknown option $1" >&2; exit 1 ;;
            *) url="$url${url:+ }$1"; shift ;;
        esac
    done

    [[ -z "$url" ]] && { echo "fetch-page: no URL" >&2; exit 1; }

    curl -sL --max-time 20 -A "$USER_AGENT" "$url" | trafilatura 2>/dev/null || true
}

# ── agents daemon helpers ──────────────────────────────────────────
DAEMON_DIR="$HOME/.pi/my-commands/daemon"
DAEMON_SOCK="$HOME/.pi/agent/.agents-daemon.sock"
DAEMON_PID="$HOME/.pi/agent/.agents-daemon.pid"

agent_daemon_running() {
    systemctl --user is-active --quiet pi-agents-daemon.service 2>/dev/null
}

agent_daemon_start() {
    if agent_daemon_running; then return 0; fi

    # Start via systemd (handles lifecycle, restart, logging)
    if ! systemctl --user start pi-agents-daemon.service 2>/dev/null; then
        echo "agent: failed to start daemon via systemd" >&2
        return 1
    fi

    # Wait for socket to appear (max 15s)
    for i in $(seq 1 30); do
        [[ -S "$DAEMON_SOCK" ]] && return 0
        sleep 0.5
    done

    echo "agent: daemon failed to start" >&2
    return 1
}

agent_send() {
    # $1 = JSON command, returns response line
    local response
    response=$(echo "$1" | ncat -U -w 10 "$DAEMON_SOCK" 2>/dev/null) || {
        echo "agent: daemon not responding" >&2
        return 1
    }
    echo "$response"
}

# ── agent subcommands ──────────────────────────────────────────────
do_agent() {
    [[ $# -lt 1 ]] && { echo "agent: no subcommand" >&2; exit 1; }

    local subcmd="$1"; shift

    case "$subcmd" in
        spawn)
            do_agent_spawn "$@" ;;
        message)
            do_agent_message "$@" ;;
        messages)
            do_agent_messages "$@" ;;
        status)
            do_agent_status "$@" ;;
        kill)
            do_agent_kill "$@" ;;
        stop)
            do_agent_stop "$@" ;;
        *)
            echo "agent: unknown subcommand '$subcmd'" >&2
            echo "Usage: my-commands agent <spawn|message|messages|status|kill|stop>" >&2
            exit 1 ;;
    esac
}

# ── agent spawn ────────────────────────────────────────────────────
do_agent_spawn() {
    local name="" prompt="" model=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --model) model="$2"; shift 2 ;;
            -*) echo "agent spawn: unknown option $1" >&2; exit 1 ;;
            *)
                [[ -z "$name" ]] && name="$1" || prompt="$prompt${prompt:+ }$1"
                shift ;;
        esac
    done
    [[ -z "$name" || -z "$prompt" ]] && {
        echo "agent spawn: requires name and prompt" >&2
        echo "Usage: my-commands agent spawn <name> [\"prompt\"]" >&2
        exit 1
    }

    agent_daemon_start || exit 1

    local json
    json=$(jq -nc --arg cmd spawn --arg name "$name" --arg prompt "$prompt" --arg model "$model" \
        '{cmd: $cmd, name: $name, prompt: $prompt, model: $model} | if ($model == "") then del(.model) else . end')

    local response
    response=$(agent_send "$json")

    if jq -e '.ok' <<< "$response" &>/dev/null; then
        echo "Spawned agent: $name"
    else
        echo "agent: $(jq -r '.error // "unknown error"' <<< "$response")" >&2
        exit 1
    fi
}

# ── agent message ──────────────────────────────────────────────────
do_agent_message() {
    local name="" prompt=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) echo "agent message: unknown option $1" >&2; exit 1 ;;
            *)
                [[ -z "$name" ]] && name="$1" || prompt="$prompt${prompt:+ }$1"
                shift ;;
        esac
    done
    [[ -z "$name" || -z "$prompt" ]] && {
        echo "agent message: requires name and prompt" >&2
        exit 1
    }

    agent_daemon_start || exit 1

    local json
    json=$(jq -nc --arg cmd message --arg name "$name" --arg prompt "$prompt" \
        '{cmd: $cmd, name: $name, prompt: $prompt}')

    local response
    response=$(agent_send "$json")

    if jq -e '.ok' <<< "$response" &>/dev/null; then
        echo "Message sent to: $name"
    else
        echo "agent: $(jq -r '.error // "unknown error"' <<< "$response")" >&2
        exit 1
    fi
}

# ── agent messages ─────────────────────────────────────────────────
do_agent_messages() {
    local name="" tail=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tail) tail="$2"; shift 2 ;;
            -*) echo "agent messages: unknown option $1" >&2; exit 1 ;;
            *) name="$1"; shift ;;
        esac
    done
    [[ -z "$name" ]] && {
        echo "agent messages: requires name" >&2
        exit 1
    }

    agent_daemon_start || exit 1

    local json
    if [[ -n "$tail" ]]; then
        json=$(jq -nc --arg cmd messages --arg name "$name" --argjson tail "$tail" \
            '{cmd: $cmd, name: $name, tail: $tail}')
    else
        json=$(jq -nc --arg cmd messages --arg name "$name" \
            '{cmd: $cmd, name: $name}')
    fi

    local response
    response=$(agent_send "$json")

    if ! jq -e '.ok' <<< "$response" &>/dev/null; then
        echo "agent: $(jq -r '.error // "unknown error"' <<< "$response")" >&2
        exit 1
    fi

    # Format output
    local count shown
    count=$(jq -r '.data.messageCount' <<< "$response")
    shown=$(jq -r '.data.shown' <<< "$response")
    echo "=== Agent: $name ($count messages, showing $shown) ==="
    echo ""

    jq -r '.data.messages[] | "[\(.role)] \(.content)"' <<< "$response"
}

# ── agent status ───────────────────────────────────────────────────
do_agent_status() {
    agent_daemon_start || exit 1

    local json
    json=$(jq -nc '{cmd: "status"}')

    local response
    response=$(agent_send "$json")

    if ! jq -e '.ok' <<< "$response" &>/dev/null; then
        echo "agent: $(jq -r '.error // "unknown error"' <<< "$response")" >&2
        exit 1
    fi

    local agent_count
    agent_count=$(jq '.data.agents | length' <<< "$response")
    echo "=== Agents: $agent_count running ==="
    echo ""

    jq -r '.data.agents[] | "\(.name)\t[\(if .streaming then "streaming" else "idle" end)]\t\(.messageCount) msgs\(if .preview then "\t" + .preview else "" end)"' <<< "$response"
}

# ── agent kill ─────────────────────────────────────────────────────
do_agent_kill() {
    local name="" kill_all=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) kill_all=true; shift ;;
            -*) echo "agent kill: unknown option $1" >&2; exit 1 ;;
            *) name="$1"; shift ;;
        esac
    done

    agent_daemon_start || exit 1

    local json
    if [[ "$kill_all" == true ]]; then
        json=$(jq -nc '{cmd: "kill-all"}')
        local response
        response=$(agent_send "$json")
        if jq -e '.ok' <<< "$response" &>/dev/null; then
            echo "Killed all $(jq -r '.data.killed' <<< "$response") agents"
        fi
    else
        [[ -z "$name" ]] && {
            echo "agent kill: requires name or --all" >&2
            exit 1
        }
        json=$(jq -nc --arg cmd kill --arg name "$name" '{cmd: $cmd, name: $name}')
        local response
        response=$(agent_send "$json")
        if jq -e '.ok' <<< "$response" &>/dev/null; then
            echo "Killed agent: $name"
        else
            echo "agent: $(jq -r '.error // "unknown error"' <<< "$response")" >&2
            exit 1
        fi
    fi
}

# ── agent stop ─────────────────────────────────────────────────────
do_agent_stop() {
    if ! agent_daemon_running; then
        echo "Daemon not running"
        return 0
    fi

    # Stop via systemd (graceful shutdown, cleanup handled by daemon)
    systemctl --user stop pi-agents-daemon.service 2>/dev/null
    echo "Daemon stopped"
}

# ── Main dispatcher ────────────────────────────────────────────────
if [[ $# -lt 1 ]]; then
    echo "my-commands: no command given" >&2
    echo "Usage: my-commands <web-search|fetch-page|agent|help> [args...]" >&2
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
    web-search)  do_web_search "$@" ;;
    fetch-page)  do_fetch_page "$@" ;;
    agent)       do_agent "$@" ;;
    help|--help|-h)
        sed -n '1,/^set -euo pipefail/p' "$0" | head -n -1
        ;;
    *)
        echo "my-commands: unknown command '$COMMAND'" >&2
        echo "Usage: my-commands <web-search|fetch-page|agent|help> [args...]" >&2
        exit 1
        ;;
esac
